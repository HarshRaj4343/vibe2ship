rules_version = '2';

// UrbanPulse — production-shaped Firestore rules.
//
// Design constraint: the app works fully signed-out (anonymous browser id) and
// all writes go through the Firebase *client* SDK (the Next.js API routes also
// use it, server-side, with no Admin credentials). So we cannot gate writes on
// request.auth. Instead we harden by:
//   • whitelisting exactly which fields a create may set, with type checks,
//   • restricting updates to the mutable subset (status, counters, AI artifacts),
//     and pinning immutable fields (reportedBy, createdAt, lat/lng, geohash),
//   • making upvotes append-only and blocking all client deletes.
// This is a real tightening over the permissive "allow if true" seed rules while
// keeping every app flow functional. For a hardened multi-tenant deployment,
// move writes behind the Admin SDK and require request.auth here.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers -----------------------------------------------------------
    function isString(v) { return v is string; }
    function isNumberInRange(v, lo, hi) { return v is number && v >= lo && v <= hi; }
    function unchanged(field) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == resource.data[field];
    }

    // ---- issues ------------------------------------------------------------
    match /issues/{issueId} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasAll(
          ['title', 'category', 'severity', 'status', 'lat', 'lng', 'geohash', 'reportedBy']
        )
        && isString(request.resource.data.title)
        && request.resource.data.category in
             ['pothole', 'water_leak', 'streetlight', 'waste', 'other']
        && isNumberInRange(request.resource.data.severity, 1, 5)
        && request.resource.data.status in ['open', 'in_progress', 'resolved']
        && isNumberInRange(request.resource.data.lat, -90, 90)
        && isNumberInRange(request.resource.data.lng, -180, 180)
        && isString(request.resource.data.geohash)
        && isString(request.resource.data.reportedBy);

      // Updates may only touch the mutable, app-managed fields. Identity and
      // location are pinned for the life of the issue.
      allow update: if
        unchanged('reportedBy')
        && unchanged('createdAt')
        && unchanged('lat')
        && unchanged('lng')
        && unchanged('geohash')
        && (!('status' in request.resource.data) ||
            request.resource.data.status in ['open', 'in_progress', 'resolved'])
        && (!('severity' in request.resource.data) ||
            isNumberInRange(request.resource.data.severity, 1, 5));

      allow delete: if false;
    }

    // ---- users -------------------------------------------------------------
    match /users/{userId} {
      allow read: if true;
      // Profile + gamification doc. Pin the immutable creation timestamp.
      allow create: if true;
      allow update: if unchanged('createdAt');
      allow delete: if false;
    }

    // ---- upvotes (append-only) --------------------------------------------
    match /upvotes/{upvoteId} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasAll(['issueId', 'userId'])
        && isString(request.resource.data.issueId)
        && isString(request.resource.data.userId);
      allow update, delete: if false;
    }
  }
}
